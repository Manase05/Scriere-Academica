using namespace std;
using namespace std::chrono;


void bubbleSort(vector<int>& arr) {
    int n = arr.size();
    for (int i = 0; i < n - 1; i++)
        for (int j = 0; j < n - i - 1; j++)
            if (arr[j] > arr[j + 1])
                swap(arr[j], arr[j + 1]);
}

void selectionSort(vector<int>& arr) {
    int n = arr.size();
    for (int i = 0; i < n - 1; i++) {
        int min_idx = i;
        for (int j = i + 1; j < n; j++)
            if (arr[j] < arr[min_idx])
                min_idx = j;
        swap(arr[min_idx], arr[i]);
    }
}

void insertionSort(vector<int>& arr) {
    int n = arr.size();
    for (int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;
        while (j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j = j - 1;
        }
        arr[j + 1] = key;
    }
}

void merge(vector<int>& arr, int l, int m, int r) {
    int n1 = m - l + 1;
    int n2 = r - m;
    vector<int> L(n1), R(n2);
    for (int i = 0; i < n1; i++) L[i] = arr[l + i];
    for (int j = 0; j < n2; j++) R[j] = arr[m + 1 + j];
    int i = 0, j = 0, k = l;
    while (i < n1 && j < n2) {
        if (L[i] <= R[j]) arr[k++] = L[i++];
        else arr[k++] = R[j++];
    }
    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];
}

void mergeSort(vector<int>& arr, int l, int r) {
    if (l < r) {
        int m = l + (r - l) / 2;
        mergeSort(arr, l, m);
        mergeSort(arr, m + 1, r);
        merge(arr, l, m, r);
    }
}

void quickSort(vector<int>& arr, int left, int right) {
    int i = left, j = right;
    int pivot = arr[left + (right - left) / 2];
    while (i <= j) {
        while (arr[i] < pivot) i++;
        while (arr[j] > pivot) j--;
        if (i <= j) {
            swap(arr[i], arr[j]);
            i++; j--;
        }
    }
    if (left < j) quickSort(arr, left, j);
    if (i < right) quickSort(arr, i, right);
}


enum DataType { RANDOM, SORTED, REVERSE_SORTED, NEARLY_SORTED, FLAT };

vector<int> generateData(int n, DataType type) {
    vector<int> data(n);
    random_device rd;
    mt19937 gen(rd());

    if (type == RANDOM) {
        uniform_int_distribution<> dis(1, 1000000);
        for (int& x : data) x = dis(gen);
    } else if (type == SORTED) {
        for (int i = 0; i < n; i++) data[i] = i;
    } else if (type == REVERSE_SORTED) {
        for (int i = 0; i < n; i++) data[i] = n - i;
    } else if (type == NEARLY_SORTED) {
        for (int i = 0; i < n; i++) data[i] = i;
        uniform_int_distribution<> dis(0, n - 1);
        for (int i = 0; i < n / 20; i++) swap(data[dis(gen)], data[dis(gen)]);
    } else if (type == FLAT) {
        uniform_int_distribution<> dis(1, 10);
        for (int& x : data) x = dis(gen);
    }
    return data;
}


double measureTime(void (*sortFunc)(vector<int>&), vector<int>& data) {
    auto start = high_resolution_clock::now();
    sortFunc(data);
    auto end = high_resolution_clock::now();
    duration<double> diff = end - start;
    return diff.count();
}

void quickSortWrapper(vector<int>& v) { if(!v.empty()) quickSort(v, 0, v.size()-1); }
void mergeSortWrapper(vector<int>& v) { if(!v.empty()) mergeSort(v, 0, v.size()-1); }
void stdSortWrapper(vector<int>& v) { sort(v.begin(), v.end()); }

int main() {
    ofstream fout("rezultate_sortare.csv");
    fout << "Algoritm,Dimensiune,TipDate,Timp(secunde)\n";

    vector<int> sizes = {10, 100, 1000, 10000, 50000};
    vector<string> typeNames = {"Random", "Sorted", "Reverse", "NearlySorted", "Flat"};

    struct Algo {
        string name;
        void (*func)(vector<int>&);
        bool isSlow;
    };

    vector<Algo> algos = {
        {"BubbleSort", bubbleSort, true},
        {"SelectionSort", selectionSort, true},
        {"InsertionSort", insertionSort, true},
        {"MergeSort", mergeSortWrapper, false},
        {"QuickSort", quickSortWrapper, false},
        {"StdSort", stdSortWrapper, false}
    };

    cout << "Incepere experiment... Rezultatele se scriu in 'rezultate_sortare.csv'\n";

    for (int n : sizes) {
        cout << "Testare pentru N = " << n << endl;
        for (int t = 0; t < 5; t++) {
            for (auto& algo : algos) {
                if (algo.isSlow && n > 20000) continue;

                vector<int> data = generateData(n, (DataType)t);

                double t_total = 0;
                int repeats = (n < 100) ? 100 : 1;

                for(int r = 0; r < repeats; r++) {
                    vector<int> copy = data;
                    t_total += measureTime(algo.func, copy);
                }

                fout << algo.name << "," << n << "," << typeNames[t] << "," << fixed << setprecision(6) << t_total/repeats << "\n";
            }
        }
    }

    fout.close();
    cout << "Gata! Deschide rezultate_sortare.csv pentru a vedea datele.\n";
    return 0;
}
